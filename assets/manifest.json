{
  "version": "2026.03.20",
  "agents": {
    "claude": {
      "root_file": {
        "path": "CLAUDE.md",
        "content": "# Claude Workspace\nFollow the project specification in `.specify/` and keep custom capabilities in `.claude/skills/`.\n",
        "policy": "never_touch_if_exists"
      },
      "directories": [
        { "path": ".claude/skills" },
        { "path": ".claude/agents" },
        { "path": ".claude/rules" }
      ],
      "files": [{
          "path": ".claude/settings.json",
          "content": "{\n  \"mcpServers\": {},\n  \"enableAgentSkills\": true\n}\n",
          "policy": "merge_json"
        }]
    },
    "codex": {
      "root_file": {
        "path": "AGENTS.md",
        "content": "# Codex Workspace\nFollow the project specification in `.specify/` and keep reusable capabilities in `.agents/skills/` and `.agents/subagents/`.\n",
        "policy": "never_touch_if_exists"
      },
      "directories": [
        { "path": ".agents/skills" },
        { "path": ".codex/agents" }
      ],
      "files": [{
          "path": ".codex/config.toml",
          "content": "[mcp_servers]\n\n[projects.'*']\ntrust_level = \"trusted\"\n",
          "policy": "create_if_missing"
        }]
    },
    "gemini": {
      "root_file": {
        "path": "GEMINI.md",
        "content": "# Gemini Workspace\nFollow the project specification in `.specify/` and store reusable prompts in `.gemini/prompts/`.\n",
        "policy": "never_touch_if_exists"
      },
      "directories": [
        { "path": ".gemini/skills" },
        { "path": ".gemini/agents" }
      ],
      "files": [{
          "path": ".gemini/settings.json",
          "content": "{\n  \"mcpServers\": {},\n  \"enableAgentSkills\": true\n}\n",
          "policy": "merge_json"
      }]
    }
  }
}
